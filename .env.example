# ================================================
# 服务配置
# ================================================
PORT=3080
# HOST=0.0.0.0
# LOG_LEVEL=INFO

# ================================================
# Gateway 鉴权配置（可选，默认自动生成）
# ================================================
# 管理员用户名（默认 admin）
# ADMIN_USERNAME=admin
# 管理员密码（默认自动生成，首次启动在控制台显示）
# ADMIN_PASSWORD=

# 会话有效期（毫秒，默认 86400000 = 24小时）
# SESSION_MAX_AGE=86400000

# 速率限制
# RATE_LIMIT_MAX_ATTEMPTS=5
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_BLOCK_MS=300000

# ================================================
# CodeBuddy 配置
# ================================================
# 凭证存储目录
# CODEBUDDY_CREDS_DIR=.codebuddy

# 企业站上游域名列表（逗号分隔），会出现在管理面板的「上游服务」下拉里
# 可填完整 URL 或仅域名；个人版域名（copilot.tencent.com / www.codebuddy.ai）会自动忽略
# 示例：
# CODEBUDDY_ENTERPRISE_HOSTS=https://abc.copilot.qq.com,https://xyz.copilot.qq.com

# ================================================
# Relay 配置
# ================================================
# 凭证存储目录
# RELAY_CREDS_DIR=.relay
